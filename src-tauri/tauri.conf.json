{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NEIS 분할점수 계산기",
  "version": "0.1.4",
  "identifier": "com.dorm.neis-cutscore",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NEIS 분할점수 계산기",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://github.com https://api.github.com"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwNzNCNEQ3NEM1Qjk4NEYKUldSUG1GdE0xN1J6VUxBdHNyNG9LVHhsT1B2Q29FQXRzeldjYW5aa3RjTE95T2dyS3JnZjdXdWgK",
      "endpoints": [
        "https://github.com/shinnanchanguk/neis-cutscore-releases/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["Korean", "English"]
      }
    }
  }
}
